{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "JH EstimateAI — FastAPI Backend",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["main:app", "--reload", "--host", "0.0.0.0", "--port", "8001"],
      "port": 8001,
      "cwd": "backend"
    },
    {
      "name": "JH EstimateAI — Next.js Frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "frontend"
    }
  ]
}
